SESSION_SECRET=replace-me

# Vynly: each user saves an agent token in Profile (users.meta). No server env token required for share/proxy.

# Supabase (database + Realtime). Required for local dev and production. Service role is server-only; never expose in HTML.
# SUPABASE_URL=
# SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=

# Destructive db/reset.js only (dev project — never on Vercel/production):
# ALLOW_DB_RESET=true
# RESET_SUPABASE_PROJECT_REF=your-project-ref

# Set to "true" to enable verbose logging (default: disabled)
# ENABLE_SESSION_LOGS=true
# ENABLE_STARTUP_LOGS=true
# ENABLE_DB_LOGS=true
# ENABLE_CREATION_LOGS=true